#!/bin/bash
echo "Waiting for the exploit to launch..."

while true; do
  PID=$(pgrep -n "exploit|pkexec|bash")

  if [ ! -z "$PID" ]; then
    clear
    # This is the line that proves what the process actually IS
    PNAME=$(cat /proc/$PID/comm 2>/dev/null)
    
    echo "!!! TARGET ACQUIRED !!!"
    echo "Tracking PID: $PID"
    echo "Process Name: $PNAME"  # <--- Proves the identity
    echo "-------------------------------------------"
    
    watch -n 0.1 "echo 'Process: \$(cat /proc/$PID/comm)'; grep -e 'Uid' /proc/$PID/status"
    break
  fi
  sleep 0.05
done